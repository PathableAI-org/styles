{
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "check:format": "prettier --check .",
    "format": "prettier --write .",
    "docs": "pnpm --filter @pathable/styles build && pnpm --filter @pathable/storybook storybook",
    "build:docs": "pnpm --filter @pathable/storybook build-storybook",
    "lint:styles": "pnpm -r run lint:styles"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "stylelint": "^16.18.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^7.0.2"
  }
}
