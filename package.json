{
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check:format": "prettier --check .",
    "format": "prettier --write .",
    "docs": "pnpm --filter @pathable/styles build && pnpm --filter @pathable/storybook storybook",
    "build:docs": "pnpm --filter @pathable/storybook build-storybook",
    "lint:styles": "pnpm -r run lint:styles",
    "lint:js": "eslint .",
    "lint:md": "markdownlint . --ignore-path .markdownlintignore",
    "lint": "pnpm lint:js && pnpm lint:styles && pnpm lint:md && pnpm check:format",
    "test:storybook": "pnpm --filter @pathable/styles build && bash scripts/test-storybook.sh apps/storybook 6006 && bash scripts/test-storybook.sh apps/storybook-react 6007",
    "test": "pnpm lint && pnpm test:storybook",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli": "^0.49.0",
    "playwright": "^1.61.1",
    "prettier": "^3.5.0",
    "stylelint": "^16.18.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^7.0.2"
  }
}
