---
const currentYear = new Date().getFullYear();

const footerLinks: { label: string; href: string }[] = [
  { label: 'Home', href: '/' },
  { label: 'Getting Started', href: '/getting-started/' },
  { label: 'Foundations', href: '/foundations/' },
  { label: 'For Agents', href: '/for-agents/' },
  { label: 'Roadmap', href: '/roadmap/' },
];
---

<footer class="doc-footer pathable-bg-surface pathable-text-primary pathable-font-family-body">
  <div class="footer-return-to-top pathable-text-center pathable-padding-2">
    <a href="#" class="pathable-text-link pathable-font-family-body">Return to top</a>
  </div>

  <div class="footer-primary-section pathable-padding-y-4 pathable-padding-x-2">
    <nav aria-label="Footer navigation">
      <div class="footer-primary-inner">
        <ul class="footer-nav-list pathable-margin-0 pathable-padding-0">
          {footerLinks.map((link) => (
            <li class="pathable-margin-0">
              <a href={link.href} class="pathable-text-link pathable-font-family-body">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer-secondary-section pathable-padding-y-3 pathable-padding-x-2">
    <div class="footer-secondary-inner pathable-display-flex pathable-flex-justify-between pathable-flex-align-center">
      <div class="footer-brand pathable-display-flex pathable-flex-align-center">
        <span class="footer-brand-name pathable-font-family-heading pathable-text-primary">PathAble Styles</span>
        <span class="footer-copyright pathable-text-muted">&copy; {currentYear} PathAble AI</span>
      </div>
      <div class="footer-attribution pathable-text-muted">Powered by USWDS</div>
    </div>
  </div>
</footer>

<style>
  .doc-footer {
    border-top: 1px solid var(--pathable-color-border);
  }

  .footer-return-to-top {
    border-bottom: 1px solid var(--pathable-color-border);
  }

  .footer-return-to-top a {
    text-decoration: none;
    font-size: 0.9rem;
  }

  .footer-return-to-top a:hover {
    text-decoration: underline;
  }

  .footer-primary-section {
    border-bottom: 1px solid var(--pathable-color-border);
  }

  .footer-primary-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
  }

  .footer-nav-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-12);
  }

  .footer-nav-list a {
    text-decoration: none;
    font-size: 0.9rem;
  }

  .footer-nav-list a:hover {
    text-decoration: underline;
  }

  .footer-secondary-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    flex-wrap: wrap;
    gap: var(--space-16);
  }

  .footer-brand {
    gap: var(--space-16);
    flex-wrap: wrap;
  }

  .footer-brand-name {
    font-size: 1.1rem;
  }

  .footer-copyright {
    font-size: 0.85rem;
  }

  .footer-attribution {
    font-size: 0.85rem;
  }
</style>