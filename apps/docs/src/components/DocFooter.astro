---
// USWDS medium footer pattern — simplified for Pathable Styles docs
// Three sections: return-to-top, primary nav links, secondary branding

const currentYear = new Date().getFullYear();

const footerLinks: { label: string; href: string }[] = [
  { label: 'Home', href: '/' },
  { label: 'Getting Started', href: '/getting-started/' },
  { label: 'Foundations', href: '/foundations/' },
  { label: 'For Agents', href: '/for-agents/' },
  { label: 'Roadmap', href: '/roadmap/' },
];
---

<footer class="doc-footer">
  <div class="footer-return-to-top">
    <a href="#">Return to top</a>
  </div>

  <div class="footer-primary-section">
    <nav aria-label="Footer navigation">
      <div class="footer-primary-inner">
        <ul class="footer-nav-list">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer-secondary-section">
    <div class="footer-secondary-inner">
      <div class="footer-brand">
        <span class="footer-brand-name">Pathable Styles</span>
        <span class="footer-copyright">&copy; {currentYear} Pathable AI</span>
      </div>
      <div class="footer-attribution">Powered by USWDS</div>
    </div>
  </div>
</footer>

<style>
  .doc-footer {
    background-color: var(--pathable-color-surface);
    color: var(--pathable-color-text);
    font-family: var(--pathable-font-body);
    border-top: 1px solid var(--pathable-color-border);
  }

  /* --- Return to top --- */
  .footer-return-to-top {
    text-align: center;
    padding: var(--space-16);
    border-bottom: 1px solid var(--pathable-color-border);
  }

  .footer-return-to-top a {
    color: var(--pathable-color-link);
    text-decoration: none;
    font-family: var(--pathable-font-body);
    font-size: 0.9rem;
  }

  .footer-return-to-top a:hover {
    text-decoration: underline;
  }

  /* --- Primary section --- */
  .footer-primary-section {
    padding: var(--space-32) var(--space-16);
    border-bottom: 1px solid var(--pathable-color-border);
  }

  .footer-primary-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
  }

  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-12);
  }

  .footer-nav-list li {
    margin: 0;
  }

  .footer-nav-list a {
    color: var(--pathable-color-link);
    text-decoration: none;
    font-family: var(--pathable-font-body);
    font-size: 0.9rem;
  }

  .footer-nav-list a:hover {
    text-decoration: underline;
  }

  /* --- Secondary section --- */
  .footer-secondary-section {
    padding: var(--space-24) var(--space-16);
  }

  .footer-secondary-inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-16);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-16);
    flex-wrap: wrap;
  }

  .footer-brand-name {
    font-family: var(--pathable-font-heading);
    font-size: 1.1rem;
    color: var(--pathable-color-text);
  }

  .footer-copyright {
    font-size: 0.85rem;
    color: var(--pathable-color-text-muted);
  }

  .footer-attribution {
    font-size: 0.85rem;
    color: var(--pathable-color-text-muted);
  }
</style>