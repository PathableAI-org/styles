{
  "name": "@pathable/styles",
  "private": true,
  "files": [
    "README.md",
    "BRAND_RULES.md",
    "AGENTS.md",
    "dist",
    "src",
    "fonts"
  ],
  "scripts": {
    "build": "node scripts/copy-fonts.mjs && sass --load-path=node_modules/@uswds/uswds/packages src/index.scss dist/styles.css",
    "watch": "sass --watch --load-path=node_modules/@uswds/uswds/packages src/index.scss dist/styles.css",
    "lint:styles": "stylelint 'src/**/*.scss'"
  },
  "dependencies": {
    "@uswds/uswds": "^3.0.0"
  },
  "devDependencies": {
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/poppins": "^5.2.7",
    "sass": "^1.86.3"
  }
}
