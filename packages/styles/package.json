{
  "name": "@pathable/styles",
  "private": true,
  "files": [
    "README.md",
    "BRAND_RULES.md",
    "AGENTS.md",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "sass --load-path=node_modules/@uswds/uswds/packages src/index.scss dist/styles.css",
    "watch": "sass --watch --load-path=node_modules/@uswds/uswds/packages src/index.scss dist/styles.css",
    "lint:styles": "stylelint 'src/**/*.scss'"
  },
  "dependencies": {
    "@uswds/uswds": "^3.0.0"
  },
  "devDependencies": {
    "sass": "^1.86.3"
  }
}
