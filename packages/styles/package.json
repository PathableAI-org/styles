{
  "name": "@pathable/styles",
  "private": true,
  "files": [
    "README.md",
    "BRAND_RULES.md",
    "AGENTS.md",
    "dist",
    "src",
    "fonts"
  ],
  "exports": {
    ".": "./dist/styles.css",
    "./js": "./dist/pathable.js",
    "./js/init": "./dist/pathable-init.js",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "node scripts/copy-icons.mjs && node scripts/copy-fonts.mjs && node scripts/build-js.mjs && sass --quiet-deps --load-path=node_modules/@uswds/uswds/packages src/index.scss dist/styles.css",
    "watch": "sass --watch --quiet-deps --load-path=node_modules/@uswds/uswds/packages src/index.scss dist/styles.css",
    "lint:styles": "stylelint 'src/**/*.scss'",
    "lint:tokens": "node scripts/lint-tokens.mjs"
  },
  "dependencies": {
    "@uswds/uswds": "^3.0.0"
  },
  "devDependencies": {
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/poppins": "^5.2.7",
    "sass": "^1.86.3",
    "esbuild": "^0.25.12"
  }
}
